# Azure OpenAI 설정 (LLM 기반 평가기 - Relevance, Groundedness, Coherence 등)
AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4

# Azure AI Foundry 프로젝트 URL (Safety 평가기, GroundednessProEvaluator, 포털 연동)
# 형식: https://{resource_name}.services.ai.azure.com/api/projects/{project_name}
AZURE_AI_PROJECT_URL=https://your-resource.services.ai.azure.com/api/projects/your-project
